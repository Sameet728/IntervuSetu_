<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@600;700;800&display=swap');

    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
      background: #ffffff;
      color: #111827;
      font-size: 13px;
      line-height: 1.5;
    }

    /* ── Utilities ─────────────────────────────────────────── */
    .page-break { page-break-after: always; }
    .no-break   { page-break-inside: avoid; }

    /* ── Palette (one accent: deep navy-blue) ────────────────
       Primary:  #1e3a5f  (deep navy)
       Accent:   #2563eb  (royal blue)
       Neutral:  shades of slate / gray
       Scores:   green / amber / red – only for numbers/dots
    ──────────────────────────────────────────────────────── */

    /* ── Aptitude (SHL) styles ──────────────────────────────── */
    .shl-cover { padding: 60px; min-height: 100vh; background: #fff; position: relative; }
    .shl-page  { padding: 44px 60px; background: #fff; min-height: 100vh; position: relative; }
    .shl-h    { font-family: 'Poppins', sans-serif; }
    .shl-section-bar { display: flex; align-items: baseline; border-bottom: 2px solid #e5e7eb; padding-bottom: 10px; margin-bottom: 24px; }
    .shl-num   { font-family: 'Poppins', sans-serif; font-size: 22px; font-weight: 800; color: #1e3a5f; margin-right: 10px; }
    .shl-title { font-family: 'Poppins', sans-serif; font-size: 22px; font-weight: 700; color: #111827; }

    /* ── Interview report styles ────────────────────────────── */
    .iv-page   { padding: 48px 52px; background: #fff; min-height: 100vh; position: relative; }
    .iv-footer { position: absolute; bottom: 22px; left: 52px; right: 52px; display: flex; justify-content: space-between; font-size: 10px; color: #9ca3af; border-top: 1px solid #f3f4f6; padding-top: 9px; }

    /* Section header */
    .sec-hdr { display: flex; align-items: flex-end; justify-content: space-between; border-bottom: 2px solid #e5e7eb; padding-bottom: 10px; margin-bottom: 28px; }
    .sec-label { font-size: 9px; font-weight: 700; color: #2563eb; text-transform: uppercase; letter-spacing: 1.4px; margin-bottom: 3px; }
    .sec-title { font-family: 'Poppins', sans-serif; font-size: 21px; font-weight: 700; color: #111827; }
    .page-num  { font-size: 10px; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 1px; }

    /* Score colors (numbers only) */
    .sc-green { color: #16a34a; }
    .sc-amber { color: #b45309; }
    .sc-red   { color: #dc2626; }

    /* Progress bar */
    .prog { height: 6px; background: #e5e7eb; border-radius: 999px; overflow: hidden; }
    .prog-bar { height: 100%; border-radius: 999px; background: #2563eb; }
    .prog-bar-green  { background: #16a34a; }
    .prog-bar-amber  { background: #b45309; }
    .prog-bar-red    { background: #dc2626; }

    /* Metric row */
    .metric-row { display: flex; align-items: center; padding: 14px 0; border-bottom: 1px solid #f3f4f6; }
    .metric-label { font-size: 13px; font-weight: 500; color: #374151; flex: 1; }
    .metric-score { font-family: 'Poppins', sans-serif; font-size: 16px; font-weight: 700; min-width: 52px; text-align: right; }
    .metric-bar-wrap { width: 200px; margin: 0 18px; }

    /* Tag badge */
    .tag { display: inline-block; padding: 2px 9px; border-radius: 4px; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.6px; border: 1px solid; }

    /* Question card */
    .q-card { border: 1px solid #e5e7eb; border-radius: 10px; padding: 22px 24px; margin-bottom: 18px; page-break-inside: avoid; background: #fff; }
    .block-label { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.3px; color: #6b7280; margin-bottom: 6px; }
    .block-box { border-radius: 8px; padding: 13px 15px; }
  </style>
</head>
<body>

<% if (isAptitude) { %>
<!-- ═══════════════════════ APTITUDE REPORT ═══════════════════════ -->

<!-- PAGE 1: COVER -->
<div class="shl-cover page-break">
  <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:56px;">
    <div style="display:flex; align-items:center; gap:9px;">
      <% if (locals.orgLogo) { %>
        <img src="<%= orgLogo %>" alt="Logo" style="height:40px; object-fit:contain;" />
      <% } else { %>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1e3a5f" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>
        <span style="font-family:Poppins,sans-serif; font-size:16px; font-weight:700; color:#1e3a5f;">InterviewAI</span>
      <% } %>
    </div>
  </div>

  <h1 style="font-family:Poppins,sans-serif; font-size:30px; font-weight:800; color:#1e3a5f; margin-bottom:18px;"><%= user.name || "Candidate" %></h1>
  <div style="font-size:12px; color:#6b7280; line-height:1.9; margin-bottom:48px; font-family:monospace;">
    <div><strong style="color:#374151;">Test ID:</strong> <%= report._id %> &nbsp;|&nbsp; <%= user.email %></div>
    <div><strong style="color:#374151;">Test Date:</strong> <%= date %></div>
  </div>

  <!-- Top-level scores -->
  <div style="margin-bottom:44px;">
    <% aptitudeInsights.forEach(cat => { %>
    <div style="display:flex; justify-content:space-between; align-items:center; padding:12px 0; border-bottom:1px solid #f3f4f6;">
      <span style="font-size:16px; font-weight:600; color:#111827;"><%= cat.title %></span>
      <span style="font-family:Poppins,sans-serif; font-size:16px; font-weight:800; color:<%= cat.score>=70?'#16a34a':cat.score>=40?'#b45309':'#dc2626' %>;"><%= cat.score %>/100</span>
    </div>
    <% }) %>
  </div>

  <!-- Sub-scores -->
  <div>
    <% aptitudeInsights.forEach(cat => { %>
    <div style="margin-bottom:30px;">
      <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:10px;">
        <span style="font-size:14px; font-weight:600; color:#1e3a5f;"><%= cat.title %></span>
        <span style="font-size:13px; font-weight:700; color:#374151;"><%= cat.score %> / 100</span>
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:12px;">
        <% cat.subscores.forEach(sub => { %>
        <div style="border:1px solid #e5e7eb; border-radius:8px; padding:14px; background:#fafafa; text-align:center;">
          <div style="font-size:10px; color:#6b7280; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:8px; min-height:28px; display:flex; align-items:center; justify-content:center;"><%= sub.name %></div>
          <div style="font-family:Poppins,sans-serif; font-size:18px; font-weight:800; color:<%= sub.score>=70?'#16a34a':sub.score>=40?'#b45309':'#dc2626' %>;"><%= sub.score %> / 100</div>
        </div>
        <% }) %>
      </div>
    </div>
    <% }) %>
  </div>

  <div style="position:absolute; bottom:36px; left:60px; right:60px; display:flex; justify-content:space-between; font-size:10px; color:#9ca3af; border-top:1px solid #f3f4f6; padding-top:10px;">
    <span>© 2026 InterviewAI. All rights reserved.</span><span>1 / 5</span>
  </div>
</div>

<!-- PAGE 2: INTRODUCTION -->
<div class="shl-page page-break">
  <div class="shl-section-bar"><span class="shl-num">1</span><span class="shl-title">Introduction</span></div>
  <h3 style="font-size:14px; font-weight:600; color:#111827; margin-bottom:8px;">About the Report</h3>
  <p style="color:#4b5563; line-height:1.8; margin-bottom:18px;">This report provides a detailed analysis of the candidate's performance on different assessments. The tests were decided based on job analysis and criterion validity studies. The candidate's responses construct a profile reflecting likely performance level and achievement potential in the job role.</p>
  <p style="color:#4b5563; line-height:1.8; margin-bottom:18px;">This report includes the following sections:</p>
  <ul style="color:#4b5563; line-height:1.9; margin-bottom:32px; padding-left:20px;">
    <li><strong>Summary</strong> — Overall snapshot with graphical score representations.</li>
    <li><strong>Insights</strong> — Detailed feedback on performance in each assessment.</li>
    <li><strong>Response</strong> — Candidate's answers to each question.</li>
    <li><strong>Learning Resources</strong> — Resources to improve knowledge and skills.</li>
  </ul>
  <h3 style="font-size:14px; font-weight:600; color:#111827; margin-bottom:8px;">Score Interpretation</h3>
  <p style="color:#4b5563; line-height:1.8; margin-bottom:14px;">All scores are on a scale of 0–100. Colour coding used throughout:</p>
  <div style="display:flex; flex-direction:column; gap:10px; max-width:240px;">
    <div style="display:flex; align-items:center; gap:12px;"><div style="width:12px; height:12px; border-radius:50%; background:#16a34a; flex-shrink:0;"></div><span style="font-size:12px; color:#374151; font-family:monospace;">70 – 100 &nbsp;(High)</span></div>
    <div style="display:flex; align-items:center; gap:12px;"><div style="width:12px; height:12px; border-radius:50%; background:#b45309; flex-shrink:0;"></div><span style="font-size:12px; color:#374151; font-family:monospace;">30 – 69 &nbsp; (Average)</span></div>
    <div style="display:flex; align-items:center; gap:12px;"><div style="width:12px; height:12px; border-radius:50%; background:#dc2626; flex-shrink:0;"></div><span style="font-size:12px; color:#374151; font-family:monospace;">0 – 29 &nbsp;&nbsp; (Low)</span></div>
  </div>
  <div style="position:absolute; bottom:36px; left:60px; right:60px; display:flex; justify-content:space-between; font-size:10px; color:#9ca3af; border-top:1px solid #f3f4f6; padding-top:10px;">
    <span>© 2026 InterviewAI. All rights reserved.</span><span>2 / 5</span>
  </div>
</div>

<!-- PAGE 3: INSIGHTS -->
<div class="shl-page page-break">
  <div class="shl-section-bar"><span class="shl-num">2</span><span class="shl-title">Insights</span></div>
  <div style="display:flex; flex-direction:column; gap:20px;">
    <% aptitudeInsights.forEach(cat => { %>
    <div class="no-break" style="border:1px solid #e5e7eb; border-radius:10px; overflow:hidden;">
      <div style="background:#f9fafb; padding:13px 18px; border-bottom:1px solid #e5e7eb; display:flex; justify-content:space-between; align-items:center;">
        <span style="font-size:14px; font-weight:600; color:#1e3a5f;"><%= cat.title %></span>
        <span style="font-family:Poppins,sans-serif; font-size:14px; font-weight:800; color:<%= cat.score>=70?'#16a34a':cat.score>=40?'#b45309':'#dc2626' %>;"><%= cat.score %> / 100</span>
      </div>
      <div style="padding:16px 18px; display:flex; flex-direction:column; gap:12px;">
        <% cat.subscores.forEach(sub => { %>
        <div>
          <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:4px;">
            <span style="font-size:12px; font-weight:500; color:#374151;"><%= sub.name %></span>
            <span style="font-size:12px; font-weight:700; color:<%= sub.score>=70?'#16a34a':sub.score>=40?'#b45309':'#dc2626' %>;"><%= sub.score %> / 100</span>
          </div>
          <p style="font-size:12px; color:#6b7280; line-height:1.7;"><%= cat.insight %></p>
        </div>
        <% }) %>
      </div>
    </div>
    <% }) %>
  </div>
  <div style="position:absolute; bottom:36px; left:60px; right:60px; display:flex; justify-content:space-between; font-size:10px; color:#9ca3af; border-top:1px solid #f3f4f6; padding-top:10px;">
    <span>© 2026 InterviewAI. All rights reserved.</span><span>3 / 5</span>
  </div>
</div>

<!-- PAGE 4: RESPONSE -->
<div class="shl-page page-break">
  <div class="shl-section-bar"><span class="shl-num">3</span><span class="shl-title">Response</span></div>
  <div style="display:flex; flex-direction:column; gap:16px;">
    <% let qi = 1; report.answers.forEach(q => {
      const ok = q.isCorrect;
    %>
    <div class="no-break" style="border:1px solid #e5e7eb; border-radius:9px; padding:16px 18px;">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
        <span style="font-size:12px; font-weight:700; color:#1e3a5f;">Question <%= qi++ %></span>
        <span style="padding:2px 10px; border-radius:4px; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.6px; background:<%= ok?'#f0fdf4':'#fef2f2' %>; color:<%= ok?'#16a34a':'#dc2626' %>; border:1px solid <%= ok?'#bbf7d0':'#fecaca' %>;"><%= ok?'Correct':'Incorrect' %></span>
      </div>
      <p style="font-size:13px; font-weight:500; color:#111827; line-height:1.65; margin-bottom:12px;"><%= q.questionId ? q.questionId.question : 'N/A' %></p>
      <div style="display:flex; flex-direction:column; gap:6px;">
        <% if (q.questionId) { q.questionId.options.forEach(opt => {
          const sel = opt._id.toString() === (q.selectedOptionId ? q.selectedOptionId.toString():'');
          const cor = opt.isCorrect;
          let bg='#fff', bd='#e5e7eb', tc='#6b7280', ic='○';
          if (cor && sel)  { bg='#f0fdf4'; bd='#86efac'; tc='#166534'; ic='✓'; }
          else if (cor)    { bg='#f0fdf4'; bd='#bbf7d0'; tc='#16a34a'; ic='✓'; }
          else if (sel)    { bg='#fef2f2'; bd='#fca5a5'; tc='#991b1b'; ic='✗'; }
        %>
        <div style="display:flex; align-items:center; gap:9px; padding:8px 12px; border-radius:6px; border:1px solid <%= bd %>; background:<%= bg %>;">
          <span style="font-weight:700; font-size:12px; color:<%= tc %>; flex-shrink:0; width:14px;"><%= ic %></span>
          <span style="font-size:12px; color:<%= tc %>;"><%= opt.text %></span>
        </div>
        <% }) } %>
      </div>
      <% if (q.questionId && q.questionId.detailedSolution) { %>
      <div style="margin-top:10px; background:#f9fafb; border:1px solid #e5e7eb; border-radius:7px; padding:11px 14px;">
        <div style="font-size:9px; font-weight:700; color:#6b7280; text-transform:uppercase; letter-spacing:1px; margin-bottom:5px;">Solution</div>
        <p style="font-size:12px; color:#374151; line-height:1.7;"><%= q.questionId.detailedSolution %></p>
      </div>
      <% } %>
    </div>
    <% }) %>
  </div>
  <div style="position:absolute; bottom:36px; left:60px; right:60px; display:flex; justify-content:space-between; font-size:10px; color:#9ca3af; border-top:1px solid #f3f4f6; padding-top:10px;">
    <span>© 2026 InterviewAI. All rights reserved.</span><span>4 / 5</span>
  </div>
</div>

<!-- PAGE 5: LEARNING RESOURCES -->
<div class="shl-page">
  <div class="shl-section-bar"><span class="shl-num">4</span><span class="shl-title">Learning Resources</span></div>
  <div style="display:flex; flex-direction:column; gap:26px;">
    <% aptitudeInsights.forEach(cat => { %>
    <div class="no-break">
      <h3 style="font-size:13px; font-weight:600; color:#111827; margin-bottom:10px;"><%= cat.title %></h3>
      <div style="display:flex; flex-direction:column; gap:7px;">
        <% cat.learning.forEach(item => { %>
        <div style="display:flex; align-items:center; gap:10px; font-size:12px; color:#4b5563;">
          <span style="width:20px; height:20px; background:#eff6ff; border:1px solid #bfdbfe; border-radius:5px; display:flex; align-items:center; justify-content:center; font-size:10px; flex-shrink:0; color:#2563eb; font-weight:700;"><%= item.type.includes('Video') ? '▶' : '⊞' %></span>
          <span><%= item.label %></span>
        </div>
        <% }) %>
      </div>
    </div>
    <% }) %>
  </div>
  <div style="position:absolute; bottom:36px; left:60px; right:60px; display:flex; justify-content:space-between; font-size:10px; color:#9ca3af; border-top:1px solid #f3f4f6; padding-top:10px;">
    <span>© 2026 InterviewAI. All rights reserved.</span><span>End of Report</span>
  </div>
</div>

<% } else { %>
<!-- ═══════════════════════ INTERVIEW REPORT — PROFESSIONAL LIGHT ═══════════════════════ -->

<!-- ── PAGE 1: COVER ──────────────────────────────────────────────────────── -->
<div style="min-height:100vh; background:#fff; display:flex; flex-direction:column; position:relative;" class="page-break">

  <!-- Top blue stripe (thin, tasteful) -->
  <div style="height:4px; background:linear-gradient(90deg,#1e3a5f 0%,#2563eb 60%,#60a5fa 100%);"></div>

  <!-- Header bar -->
  <div style="padding:24px 52px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #f3f4f6;">
    <div style="display:flex; align-items:center; gap:9px;">
      <% if (locals.orgLogo) { %>
        <img src="<%= orgLogo %>" alt="Logo" style="height:32px; object-fit:contain;" />
      <% } else { %>
        <div style="width:30px; height:30px; background:#1e3a5f; border-radius:8px; display:flex; align-items:center; justify-content:center;">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>
        </div>
        <span style="font-family:Poppins,sans-serif; font-size:15px; font-weight:700; color:#1e3a5f; letter-spacing:-0.2px;">InterviewAI</span>
      <% } %>
    </div>
    <div style="text-align:right; font-size:11px; color:#9ca3af;">
      <div style="font-weight:500; color:#6b7280;"><%= date %></div>
      <div style="margin-top:1px; font-family:monospace; font-size:9px;">ID: <%= report._id %></div>
    </div>
  </div>

  <!-- Hero -->
  <div style="padding:52px 52px 40px;">
    <div style="font-size:10px; font-weight:700; color:#2563eb; text-transform:uppercase; letter-spacing:1.5px; margin-bottom:16px;">Interview Assessment Report</div>
    <h1 style="font-family:Poppins,sans-serif; font-size:42px; font-weight:800; color:#1e3a5f; line-height:1.05; letter-spacing:-0.8px; margin-bottom:18px; max-width:480px;"><%= report.role || "Performance Report" %></h1>
    <div style="display:flex; gap:8px; flex-wrap:wrap;">
      <span style="font-size:10px; font-weight:600; color:#374151; background:#f3f4f6; border:1px solid #e5e7eb; padding:4px 12px; border-radius:4px; text-transform:uppercase; letter-spacing:0.6px;"><%= String(report.interviewType || 'technical').replace(/_/g,' ') %></span>
      <span style="font-size:10px; font-weight:600; color:#374151; background:#f3f4f6; border:1px solid #e5e7eb; padding:4px 12px; border-radius:4px; text-transform:uppercase; letter-spacing:0.6px;"><%= report.experienceLevel || 'Professional' %></span>
      <% if (report.difficulty) { %>
      <span style="font-size:10px; font-weight:600; color:#374151; background:#f3f4f6; border:1px solid #e5e7eb; padding:4px 12px; border-radius:4px; text-transform:uppercase; letter-spacing:0.6px;"><%= report.difficulty %></span>
      <% } %>
    </div>
  </div>

  <!-- Info card -->
  <div style="margin:0 52px; border:1px solid #e5e7eb; border-radius:14px; overflow:hidden;">
    <div style="display:grid; grid-template-columns:1fr 1px 200px;">

      <!-- Candidate info -->
      <div style="padding:32px 36px;">
        <div style="font-size:9px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:1.5px; margin-bottom:8px;">Candidate</div>
        <div style="font-family:Poppins,sans-serif; font-size:24px; font-weight:700; color:#111827; margin-bottom:3px; letter-spacing:-0.3px;"><%= user.name || 'Candidate' %></div>
        <div style="font-size:12px; color:#6b7280; margin-bottom:24px;"><%= user.email %></div>

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
          <div style="background:#f9fafb; border:1px solid #e5e7eb; border-radius:8px; padding:13px 15px;">
            <div style="font-size:9px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:1px; margin-bottom:4px;">Duration</div>
            <div style="font-family:Poppins,sans-serif; font-size:18px; font-weight:700; color:#111827; font-family:monospace;"><%= formattedTime %></div>
          </div>
          <div style="background:#f9fafb; border:1px solid #e5e7eb; border-radius:8px; padding:13px 15px;">
            <div style="font-size:9px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:1px; margin-bottom:4px;">Questions</div>
            <div style="font-family:Poppins,sans-serif; font-size:18px; font-weight:700; color:#111827;"><%= totalQuestions %></div>
          </div>
          <% if (user.company) { %>
          <div style="background:#f9fafb; border:1px solid #e5e7eb; border-radius:8px; padding:13px 15px;">
            <div style="font-size:9px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:1px; margin-bottom:4px;">Company</div>
            <div style="font-size:13px; font-weight:600; color:#111827;"><%= user.company %></div>
          </div>
          <% } %>
          <% if (user.yearsOfExperience) { %>
          <div style="background:#f9fafb; border:1px solid #e5e7eb; border-radius:8px; padding:13px 15px;">
            <div style="font-size:9px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:1px; margin-bottom:4px;">Experience</div>
            <div style="font-size:13px; font-weight:600; color:#111827;"><%= user.yearsOfExperience %> Years</div>
          </div>
          <% } %>
        </div>
      </div>

      <!-- Divider -->
      <div style="background:#f3f4f6;"></div>

      <!-- Score -->
      <%
        const ringColor = overallScore>=8?'#16a34a':overallScore>=5?'#b45309':'#dc2626';
        const ringPct   = Math.round((overallScore/10)*100);
        const recBg     = overallScore>=8?'#f0fdf4':overallScore>=5?'#fffbeb':'#fef2f2';
        const recClr    = overallScore>=8?'#16a34a':overallScore>=5?'#b45309':'#dc2626';
        const recBdr    = overallScore>=8?'#bbf7d0':overallScore>=5?'#fcd34d':'#fecaca';
        const recTxt    = String(report.recommendation||'Pending').replace(/_/g,' ');
      %>
      <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; padding:32px 20px; background:#fafafa;">
        <div style="font-size:9px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:1.5px; margin-bottom:18px;">Overall Score</div>
        <div style="width:114px; height:114px; border-radius:50%; background:conic-gradient(<%= ringColor %> <%= ringPct %>%, #e5e7eb 0); display:flex; align-items:center; justify-content:center; margin-bottom:16px;">
          <div style="width:84px; height:84px; border-radius:50%; background:#fff; border:1px solid #f3f4f6; display:flex; flex-direction:column; align-items:center; justify-content:center; box-shadow:0 2px 6px rgba(0,0,0,0.06);">
            <span style="font-family:Poppins,sans-serif; font-size:29px; font-weight:800; color:<%= ringColor %>; line-height:1;"><%= overallScore %></span>
            <span style="font-size:10px; color:#9ca3af; font-weight:500;">/&thinsp;10</span>
          </div>
        </div>
        <div style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.8px; padding:4px 14px; border-radius:4px; background:<%= recBg %>; color:<%= recClr %>; border:1px solid <%= recBdr %>;"><%= recTxt %></div>
      </div>

    </div>
  </div>

  <div style="margin-top:auto; padding:20px 52px; display:flex; justify-content:space-between; font-size:10px; color:#9ca3af; border-top:1px solid #f9fafb; margin-top:36px;">
    <span>© 2026 InterviewAI. All rights reserved.</span><span>Page 1</span>
  </div>
</div>

<!-- ── PAGE 2: EXECUTIVE SUMMARY ──────────────────────────────────────────── -->
<div class="iv-page page-break">
  <div class="sec-hdr">
    <div><div class="sec-label">Section 1</div><div class="sec-title">Executive Summary</div></div>
    <div class="page-num">Page 2</div>
  </div>

  <!-- Score metrics — simple rows, no loud colors -->
  <div style="border:1px solid #e5e7eb; border-radius:10px; overflow:hidden; margin-bottom:24px;">
    <div style="background:#f9fafb; padding:10px 20px; border-bottom:2px solid #e5e7eb; display:grid; grid-template-columns:1fr 200px 60px; gap:16px; align-items:center;">
      <span style="font-size:10px; font-weight:700; color:#6b7280; text-transform:uppercase; letter-spacing:1px;">Skill Area</span>
      <span style="font-size:10px; font-weight:700; color:#6b7280; text-transform:uppercase; letter-spacing:1px;">Score Distribution</span>
      <span style="font-size:10px; font-weight:700; color:#6b7280; text-transform:uppercase; letter-spacing:1px; text-align:right;">Score</span>
    </div>
    <%
      const scoreMets = [
        { label:'Technical Skills',  val: report.technicalScore      || 0 },
        { label:'Communication',     val: report.communicationScore  || 0 },
        { label:'Problem Solving',   val: report.problemSolvingScore || 0 },
        { label:'HR & Culture Fit',  val: report.hrScore             || 0 },
      ];
      if (report.codeQualityScore) scoreMets.push({ label:'Code Quality', val:report.codeQualityScore });
      scoreMets.forEach((m, idx) => {
        const pct = Math.round((m.val/10)*100);
        const barClr = pct>=70?'#16a34a':pct>=50?'#b45309':'#dc2626';
        const txtClr = pct>=70?'#16a34a':pct>=50?'#b45309':'#dc2626';
    %>
    <div style="padding:13px 20px; border-bottom:<%= idx < scoreMets.length-1 ? '1px solid #f3f4f6' : 'none' %>; display:grid; grid-template-columns:1fr 200px 60px; gap:16px; align-items:center;">
      <span style="font-size:13px; font-weight:500; color:#374151;"><%= m.label %></span>
      <div style="height:6px; background:#e5e7eb; border-radius:999px; overflow:hidden;">
        <div style="height:100%; width:<%= pct %>%; background:<%= barClr %>; border-radius:999px;"></div>
      </div>
      <span style="font-family:Poppins,sans-serif; font-size:14px; font-weight:700; color:<%= txtClr %>; text-align:right;"><%= m.val %>/10</span>
    </div>
    <% }); %>
  </div>

  <!-- Charts -->
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:20px;">
    <div style="border:1px solid #e5e7eb; border-radius:10px; padding:12px; background:#fafafa; display:flex; align-items:center; justify-content:center; min-height:220px;">
      <img src="<%= radarChartUrl %>" alt="Skills Radar" style="max-height:200px; width:auto;" />
    </div>
    <div style="border:1px solid #e5e7eb; border-radius:10px; padding:12px; background:#fafafa; display:flex; align-items:center; justify-content:center; min-height:220px;">
      <img src="<%= barChartUrl %>" alt="Scores" style="max-height:200px; width:auto;" />
    </div>
  </div>

  <!-- AI Evaluation -->
  <% if (report.overallFeedback) { %>
  <div style="border-left:3px solid #2563eb; padding:14px 18px; background:#f8faff; border-radius:0 8px 8px 0; border:1px solid #dbeafe; border-left-width:3px; margin-bottom:18px;">
    <div style="font-size:9px; font-weight:700; color:#2563eb; text-transform:uppercase; letter-spacing:1.3px; margin-bottom:7px;">AI Evaluator Summary</div>
    <p style="font-size:13px; color:#1e40af; line-height:1.75;"><%= report.overallFeedback %></p>
  </div>
  <% } %>

  <!-- Strengths & Weaknesses -->
  <% if (report.strengths && report.weaknesses) { %>
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px;">
    <div style="border:1px solid #d1fae5; border-radius:10px; padding:18px;">
      <div style="font-size:9px; font-weight:700; color:#059669; text-transform:uppercase; letter-spacing:1.3px; margin-bottom:12px;">Key Strengths</div>
      <% report.strengths.forEach(s => { %>
      <div style="display:flex; gap:8px; font-size:12px; color:#065f46; padding:5px 0; border-bottom:1px solid #ecfdf5; line-height:1.55;">
        <span style="color:#16a34a; font-weight:700; flex-shrink:0; margin-top:1px;">+</span><span><%= s %></span>
      </div>
      <% }); %>
    </div>
    <div style="border:1px solid #fee2e2; border-radius:10px; padding:18px;">
      <div style="font-size:9px; font-weight:700; color:#dc2626; text-transform:uppercase; letter-spacing:1.3px; margin-bottom:12px;">Areas to Improve</div>
      <% report.weaknesses.forEach(w => { %>
      <div style="display:flex; gap:8px; font-size:12px; color:#7f1d1d; padding:5px 0; border-bottom:1px solid #fef2f2; line-height:1.55;">
        <span style="color:#dc2626; font-weight:700; flex-shrink:0; margin-top:1px;">–</span><span><%= w %></span>
      </div>
      <% }); %>
    </div>
  </div>
  <% } %>

  <div class="iv-footer">
    <span>© 2026 InterviewAI. All rights reserved.</span><span>Page 2</span>
  </div>
</div>

<!-- ── PAGE 3: PROCTORING (conditional) ──────────────────────────────────── -->
<% if (report.violationCount > 0 || (report.violations && report.violations.length > 0)) { %>
<div class="iv-page page-break">
  <div class="sec-hdr">
    <div><div class="sec-label">Section 2</div><div class="sec-title">Proctoring Report</div></div>
    <div class="page-num">Page 3</div>
  </div>

  <div style="border:1px solid #fde68a; border-radius:10px; padding:16px 20px; margin-bottom:22px; display:flex; align-items:center; gap:14px; background:#fffbeb;">
    <div style="width:38px; height:38px; border-radius:8px; background:#fef3c7; border:1px solid #fde68a; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:18px;">⚠</div>
    <div>
      <div style="font-size:13px; font-weight:600; color:#78350f; margin-bottom:2px;"><%= report.violationCount || report.violations.length %> Violation(s) Detected</div>
      <div style="font-size:12px; color:#92400e;">The candidate's environment was flagged during the assessment session.</div>
    </div>
  </div>

  <% if (report.violations && report.violations.length > 0) { %>
  <table style="width:100%; border-collapse:collapse; border:1px solid #e5e7eb; border-radius:10px; overflow:hidden;">
    <thead>
      <tr style="background:#f9fafb;">
        <th style="padding:12px 16px; text-align:left; font-size:10px; font-weight:700; color:#6b7280; text-transform:uppercase; letter-spacing:0.8px; border-bottom:2px solid #e5e7eb; width:100px;">Time</th>
        <th style="padding:12px 16px; text-align:left; font-size:10px; font-weight:700; color:#6b7280; text-transform:uppercase; letter-spacing:0.8px; border-bottom:2px solid #e5e7eb; width:140px;">Type</th>
        <th style="padding:12px 16px; text-align:left; font-size:10px; font-weight:700; color:#6b7280; text-transform:uppercase; letter-spacing:0.8px; border-bottom:2px solid #e5e7eb;">Details</th>
      </tr>
    </thead>
    <tbody>
      <% report.violations.forEach((v, i) => { %>
      <tr style="background:<%= i%2===0?'#fff':'#f9fafb' %>;">
        <td style="padding:11px 16px; font-size:11px; font-family:monospace; color:#6b7280; border-bottom:1px solid #f3f4f6;"><%= v.timestamp ? new Date(v.timestamp).toLocaleTimeString():'N/A' %></td>
        <td style="padding:11px 16px; border-bottom:1px solid #f3f4f6;"><span style="font-size:9px; font-weight:700; text-transform:uppercase; padding:2px 8px; background:#f3f4f6; border:1px solid #e5e7eb; border-radius:4px; color:#374151; letter-spacing:0.5px;"><%= v.type %></span></td>
        <td style="padding:11px 16px; font-size:12px; color:#374151; border-bottom:1px solid #f3f4f6;"><%= v.details||'—' %></td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } %>

  <div class="iv-footer">
    <span>© 2026 InterviewAI. All rights reserved.</span><span>Page 3</span>
  </div>
</div>
<% } %>

<!-- ── PAGE 4+: QUESTION ANALYSIS ─────────────────────────────────────────── -->
<div class="iv-page">
  <%
    const hasViol = report.violationCount>0||(report.violations&&report.violations.length>0);
    const sNum = hasViol?3:2, pNum = hasViol?4:3;
  %>
  <div class="sec-hdr">
    <div><div class="sec-label">Section <%= sNum %></div><div class="sec-title">Detailed Question Analysis</div></div>
    <div class="page-num">Page <%= pNum %></div>
  </div>

  <% report.questionBreakdown.forEach((q, i) => {
    const sc     = q.score || 0;
    const pct    = Math.round((sc/10)*100);
    const scClr  = sc>=8?'#16a34a':sc>=5?'#b45309':'#dc2626';
    const scBg   = sc>=8?'#f0fdf4':sc>=5?'#fffbeb':'#fef2f2';
    const scBdr  = sc>=8?'#bbf7d0':sc>=5?'#fcd34d':'#fecaca';
    const barClr = sc>=8?'#16a34a':sc>=5?'#b45309':'#dc2626';
    const accentL= sc>=8?'#16a34a':sc>=5?'#b45309':'#dc2626';
    const qTL    = String(q.questionType||'theory').replace(/_/g,' ').toUpperCase();
  %>
  <div class="no-break" style="border:1px solid #e5e7eb; border-radius:10px; margin-bottom:16px; overflow:hidden; background:#fff;">

    <!-- Card top bar colored by score -->
    <div style="height:3px; background:<%= accentL %>;"></div>

    <div style="padding:20px 22px;">
      <!-- Header row -->
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; flex-wrap:wrap; gap:8px;">
        <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
          <span style="font-family:Poppins,sans-serif; font-size:12px; font-weight:700; color:#1e3a5f; background:#eff6ff; border:1px solid #bfdbfe; padding:3px 11px; border-radius:5px;">Q<%= i+1 %></span>
          <span style="font-size:9px; font-weight:700; color:#6b7280; background:#f3f4f6; border:1px solid #e5e7eb; padding:2px 9px; border-radius:4px; text-transform:uppercase; letter-spacing:0.6px;"><%= qTL %></span>
          <% if (q.difficulty) { %>
          <span style="font-size:9px; font-weight:600; color:#374151; background:#f9fafb; border:1px solid #e5e7eb; padding:2px 9px; border-radius:4px; text-transform:uppercase;"><%= q.difficulty %></span>
          <% } %>
          <% if (q.topic) { %>
          <span style="font-size:9px; font-weight:600; color:#2563eb; background:#eff6ff; border:1px solid #bfdbfe; padding:2px 9px; border-radius:4px;"><%= q.topic %></span>
          <% } %>
        </div>
        <div style="background:<%= scBg %>; border:1px solid <%= scBdr %>; border-radius:7px; padding:5px 14px; flex-shrink:0;">
          <span style="font-family:Poppins,sans-serif; font-size:18px; font-weight:800; color:<%= scClr %>; line-height:1;"><%= sc %></span><span style="font-size:11px; color:#9ca3af; font-weight:500;">/10</span>
        </div>
      </div>

      <!-- Progress bar -->
      <div style="height:4px; background:#f3f4f6; border-radius:999px; overflow:hidden; margin-bottom:14px;">
        <div style="height:100%; width:<%= pct %>%; background:<%= barClr %>; border-radius:999px;"></div>
      </div>

      <!-- Question -->
      <div style="background:#f9fafb; border:1px solid #e5e7eb; border-radius:8px; padding:12px 15px; margin-bottom:10px;">
        <div style="font-size:9px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:1.2px; margin-bottom:5px;">Question</div>
        <p style="font-size:13px; font-weight:500; color:#111827; line-height:1.65; margin:0;"><%= q.question %></p>
      </div>

      <!-- Candidate answer -->
      <div style="background:#f0f6ff; border:1px solid #dbeafe; border-radius:8px; padding:12px 15px; margin-bottom:10px;">
        <div style="font-size:9px; font-weight:700; color:#2563eb; text-transform:uppercase; letter-spacing:1.2px; margin-bottom:5px;">Candidate's Answer</div>
        <p style="font-size:13px; color:#1e3a5f; line-height:1.65; margin:0; white-space:pre-wrap;"><%= q.userAnswer||'No answer recorded.' %></p>
      </div>

      <% if (q.userCode) { %>
      <div style="background:#0f172a; border-radius:8px; padding:12px 15px; margin-bottom:10px;">
        <div style="font-size:9px; font-weight:700; color:#60a5fa; text-transform:uppercase; letter-spacing:1.2px; margin-bottom:7px;">Code Submission</div>
        <pre style="font-size:11px; color:#e2e8f0; margin:0; white-space:pre-wrap; font-family:'Courier New',monospace; line-height:1.55;"><%= q.userCode %></pre>
      </div>
      <% } %>

      <!-- AI feedback -->
      <% if (q.feedback) { %>
      <div style="border-left:3px solid #6b7280; padding:11px 15px; background:#f9fafb; border-radius:0 7px 7px 0; border:1px solid #e5e7eb; border-left-width:3px; margin-bottom:10px;">
        <div style="font-size:9px; font-weight:700; color:#6b7280; text-transform:uppercase; letter-spacing:1.2px; margin-bottom:5px;">Evaluator Notes</div>
        <p style="font-size:12px; color:#374151; line-height:1.7; margin:0;"><%= q.feedback %></p>
      </div>
      <% } %>

      <!-- Ideal answer -->
      <% if (q.idealAnswer) { %>
      <div style="border-left:3px solid #16a34a; padding:11px 15px; background:#f0fdf4; border-radius:0 7px 7px 0; border:1px solid #d1fae5; border-left-width:3px;">
        <div style="font-size:9px; font-weight:700; color:#16a34a; text-transform:uppercase; letter-spacing:1.2px; margin-bottom:5px;">Model Answer</div>
        <p style="font-size:12px; color:#14532d; line-height:1.7; margin:0;"><%= q.idealAnswer %></p>
      </div>
      <% } %>
    </div>
  </div>
  <% }); %>

  <div class="iv-footer">
    <span>© 2026 InterviewAI. All rights reserved.</span><span>End of Report</span>
  </div>
</div>

<% } %>

</body>
</html>
